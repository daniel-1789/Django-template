# Copy to .env and fill in. .env is gitignored. Loaded by django-environ in
# config/settings.py.

# --- Django ---
# Generate a real one for anything non-local:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true

# DATABASE_URL is the single switch between backends — pick ONE.

# --- SQLite (single local file; zero setup; the default) ---
# Three slashes = path relative to CWD, four = absolute.
DATABASE_URL=sqlite:///./django_app.db

# --- MySQL (networked) ---
# Format: mysql://<user>:<password>@<host>:<port>/<database>
# Served via PyMySQL (see config/__init__.py), so no C build toolchain needed.
# DATABASE_URL=mysql://root:root@127.0.0.1:3306/django_app
