# Copy to .env and fill in. .env is gitignored.
# DATABASE_URL is the single switch between backends — pick ONE.

# --- SQLite (single local file; zero setup; the default) ---
# Three slashes = path relative to CWD, four = absolute. ":memory:" is not
# recommended here (each connection in the pool gets its own empty DB).
DATABASE_URL=sqlite:///./flask_app.db

# --- MySQL (networked) ---
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
# DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/flask_app
